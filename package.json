{
    "name": "decision-tree-agent",
    "version": "1.0.0",
    "description": "Create a decision tree mulit-agent system",
    "main": "agent.ts",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "lint": "npx eslint . --ext .ts",
        "lint:fix": "npx eslint . --ext .ts --fix",
        "prebuild": "rimraf dist",
        "build": "npx tsc --project tsconfig.json",
        "cli": "npm run build && npx @google/adk-devtools run dist/agent.js",
        "web": "npm run build && npx @google/adk-devtools web --host 127.0.0.1 dist/agent.js",
        "prepare": "husky",
        "lint-staged": "lint-staged --allow-empty",
        "format": "prettier . --write"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "@google/adk": "0.5.0",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@commitlint/cli": "20.4.4",
        "@commitlint/config-conventional": "20.4.4",
        "@eslint/js": "^10.0.1",
        "@google/adk-devtools": "0.5.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "husky": "9.1.7",
        "jiti": "2.6.1",
        "lint-staged": "16.4.0",
        "prettier": "3.8.1",
        "rimraf": "^6.1.3",
        "typescript": "5.9.3",
        "typescript-eslint": "^8.57.0"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{md, json}": [
            "prettier --write"
        ]
    }
}
